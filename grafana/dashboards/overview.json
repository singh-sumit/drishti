{
  "id": null,
  "uid": "drishti-overview",
  "title": "Drishti Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["drishti", "overview"],
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Runtime by Process",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (comm) (rate(drishti_cpu_run_time_ns_total[1m]))", "refId": "A"}
      ],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RSS by Process",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "topk(10, drishti_mem_rss_bytes)", "refId": "A"}
      ],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Process Lifecycle Events",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event) (rate(drishti_proc_lifecycle_total[1m]))", "refId": "A"}
      ],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "System Memory",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "drishti_mem_available_bytes", "legendFormat": "available", "refId": "A"},
        {"expr": "drishti_mem_cache_bytes", "legendFormat": "cache", "refId": "B"},
        {"expr": "drishti_mem_total_bytes", "legendFormat": "total", "refId": "C"}
      ],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
    }
  ]
}
