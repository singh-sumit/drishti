{
  "id": null,
  "uid": "drishti-process",
  "title": "Drishti Process Focus",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["drishti", "process"],
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Top CPU Runtime",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "topk(20, drishti_cpu_run_time_ns_total)", "refId": "A", "format": "table"}
      ],
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Wait Time by Process",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum by (comm) (rate(drishti_cpu_wait_time_ns_total[1m]))", "refId": "A"}
      ],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Major Faults by Process",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum by (comm) (rate(drishti_mem_page_faults_major_total[1m]))", "refId": "A"}
      ],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top Network TX Bytes",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "topk(20, drishti_net_tx_bytes_total)", "refId": "A", "format": "table"}
      ],
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Disk Latency by Device",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, device) (rate(drishti_disk_io_latency_usec_bucket[5m])))", "refId": "A"}
      ],
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8}
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top Syscall Volume",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "topk(20, drishti_syscall_count_total)", "refId": "A", "format": "table"}
      ],
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Syscall p95 Latency by Name",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, syscall) (rate(drishti_syscall_latency_usec_bucket[5m])))", "refId": "A"}
      ],
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8}
    }
  ]
}
