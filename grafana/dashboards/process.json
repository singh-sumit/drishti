{
  "id": null,
  "uid": "drishti-process",
  "title": "Drishti Process Focus",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["drishti", "process"],
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Top CPU Runtime",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "topk(20, drishti_cpu_run_time_ns_total)", "refId": "A", "format": "table"}
      ],
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Wait Time by Process",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (comm) (rate(drishti_cpu_wait_time_ns_total[1m]))", "refId": "A"}
      ],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Major Faults by Process",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (comm) (rate(drishti_mem_page_faults_major_total[1m]))", "refId": "A"}
      ],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
    }
  ]
}
